# Copy this file to .env.local and fill in the values that apply to your
# environment. Anything starting with NEXT_PUBLIC_ is exposed to the client
# bundle — do not put secrets here.

# ---------------------------------------------------------------------------
# Required for trading
# ---------------------------------------------------------------------------

# Privy app ID — create one at https://dashboard.privy.io.
# Without this set, the screener still runs in read-only mode but the
# Connect-wallet button is disabled.
NEXT_PUBLIC_PRIVY_APP_ID=

# ---------------------------------------------------------------------------
# Recommended for production
# ---------------------------------------------------------------------------

# Polygon RPC URL. Defaults to the public endpoint, which rate-limits hard at
# scale. Free tier of Alchemy / QuickNode / Infura is enough.
NEXT_PUBLIC_POLYGON_RPC_URL=https://polygon-rpc.com

# Public site URL — used by sitemap.ts, robots.ts, and absolute OG image URLs.
# Set this to your production domain in the deploy environment.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Optional analytics
# ---------------------------------------------------------------------------

# Set to your registered Plausible domain (e.g. hunch.to) to inject the
# analytics script. The default script src is plausible.io's public host —
# override NEXT_PUBLIC_PLAUSIBLE_SCRIPT_SRC for self-hosted instances.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_SCRIPT_SRC=https://plausible.io/js/script.js

# Disqus comments shortname. Register a free site at https://disqus.com/admin/
# (choose "I want to install Disqus on my site"). The shortname is the unique
# identifier you pick — typically your domain without the TLD (e.g. `hunch-to`).
# When unset, the comments section on each market page renders nothing.
NEXT_PUBLIC_DISQUS_SHORTNAME=

# Sentry: not yet integrated. To add, `npm i @sentry/nextjs`, then run
# `npx @sentry/wizard@latest -i nextjs` and follow the prompts. The wizard
# creates instrumentation files that read from these env vars:
#   NEXT_PUBLIC_SENTRY_DSN=
#   SENTRY_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# Notes
# ---------------------------------------------------------------------------
# - The Polymarket builder code is hardcoded in lib/polymarket.ts and is not
#   sensitive (it's a public bytes32 the user has registered for attribution).
# - The CLOB host (https://clob.polymarket.com) is also hardcoded since V2
#   has a single canonical endpoint.
# - L2 API credentials are derived per-session from a one-time wallet sign and
#   cached in sessionStorage — never read from this file.
