# Wallet private key (hex, with or without 0x prefix).
# Use a FRESH wallet for the builder identity — don't reuse main trading wallets.
POLY_PK=0x...

# Builder code from polymarket.com/settings?tab=builder
# Format: 0x-prefixed bytes32 hex string.
POLY_BUILDER_CODE=0x...

# Funder address — only required when signing for a Safe / Magic proxy wallet.
# Leave blank for a plain EOA.
POLY_FUNDER=

# Signature type:
#   0 = EOA (default; right answer for a fresh self-custodied wallet)
#   1 = Safe
#   2 = Magic / Polymarket proxy
POLY_SIG_TYPE=0

# L2 API credentials, generated at polymarket.com/settings?tab=relayer-api-keys
# Required when funder is a smart-contract deposit wallet (SIG_TYPE=3) — the
# auto-derive flow only works for plain EOAs.
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASS_PHRASE=

# Optional overrides — defaults are mainnet.
# POLY_CLOB_HOST=https://clob.polymarket.com
# POLY_CHAIN_ID=137
